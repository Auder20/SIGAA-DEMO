# SIGAA Django Project - Environment Variables Template
# Copy this file to .env and configure with your actual values

# ===================================================================
# SECURITY CRITICAL SETTINGS
# ===================================================================

# Generate a new secret key: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secure-secret-key-here-minimum-50-characters

# DEBUG should be False in production!
DEBUG=False

# Allowed hosts for your domain
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# SSL/TLS Configuration (set to True in production with HTTPS)
USE_SSL=False

# ===================================================================
# DATABASE CONFIGURATION
# ===================================================================

# Database engine (sqlite3 for development, postgresql/mysql for production)
DB_ENGINE=django.db.backends.sqlite3

# For SQLite (default)
DB_NAME=sigaa_demo.db

# For PostgreSQL/MySQL (uncomment and configure)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=sigaa_production
# DB_USER=sigaa_user
# DB_PASSWORD=secure_password
# DB_HOST=localhost
# DB_PORT=5432

# ===================================================================
# EMAIL CONFIGURATION (for password reset, notifications)
# ===================================================================

# Email backend
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# SMTP settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=SIGAA <noreply@yourdomain.com>

# ===================================================================
# OPTIONAL: DEVELOPMENT SETTINGS
# ===================================================================

# Uncomment for development to override production settings
# DEBUG=True
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
